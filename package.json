{
  "name": "ledger-banking-system",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "build:client": "npm run build --prefix client",
    "dev:server": "nest start --watch",
    "dev:client": "npm run dev --prefix client",
    "start": "node dist/main.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "test:smoke": "nest build && node -r reflect-metadata dist/scripts/smoke-transfer.js",
    "test:concurrency": "nest build && node -r reflect-metadata dist/scripts/test-concurrency.js"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.0",
    "@nestjs/core": "^11.1.0",
    "@nestjs/platform-express": "^11.1.0",
    "@nestjs/serve-static": "^5.0.3",
    "@prisma/client": "^6.9.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "decimal.js": "^10.5.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.7",
    "@nestjs/schematics": "^11.0.5",
    "@types/express": "^5.0.0",
    "@types/node": "^22.15.0",
    "prisma": "^6.9.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
